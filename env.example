# ==========================================
# GRSAI API (Gemini 原生)
# ==========================================
GRSAI_OPENAI_API_KEY=sk-你的API_KEY
GRSAI_OPENAI_API_BASE=https://grsai.dakka.com.cn

# ==========================================
# 大语言模型配置
# ==========================================
OPENAI_API_KEY=sk-你的API_KEY
OPENAI_API_BASE=https://api.deepseek.com/v1

# ==========================================
# 其他 API (按需填写)
# ==========================================
ZHENZHEN_OPENAI_API_KEY=sk-你的API_KEY
ZHENZHEN_OPENAI_API_BASE=https://ai.t8star.org

API_KEY=sk-你的API_KEY
AI6700_BASE_URL=https://api.ai6800.com

# ==========================================
# Qwen VL 视觉理解
# ==========================================
DASHSCOPE_API_KEY=sk-你的API_KEY
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen3-max-2026-01-23
QWEN_VL_MODEL=qwen3-vl-plus

# ==========================================
# 视频生成配置 (Seedance / ARK)
# ==========================================
ARK_API_KEY=你的API_KEY
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_TASK_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# ==========================================
# 通用模型名称
# ==========================================
PROMPT_MODEL=gpt-5.5
PROMPT_FALLBACK_MODEL=gpt-5.5-pro
NANO_BANANA_MODEL=gemini-3-pro-image-preview
NANO_BANANA2_MODEL=gemini-3.1-flash-image-preview
GPT_IMAGE2_MODEL=gpt-image-2
